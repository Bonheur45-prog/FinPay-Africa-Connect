# Environment Configuration
NODE_ENV=development

# Server
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/finpay-cms

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
